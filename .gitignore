# ─────────────────────────────────────────────────────
# Argus project-specific
# ─────────────────────────────────────────────────────

# Claude Code local config (Bash 权限白名单等)
.claude/

# Test cases (各项目独立 repo 或本地数据，不进 argus repo)
# 注意：用 `tests/*` 而不是 `tests/` —— 后者会让 git 不再递归进入该目录，
# 导致下面的 `!tests/_template/` 例外失效。
tests/*
# 例外：tests/_template 是 argus 自带的「新项目骨架」模板，需要进 argus repo
# 供其他人 clone 后参考（_accounts.json.example / README 写法等）
!tests/_template/
!tests/_template/**

# Argus run artifacts (报告/截图/缓存)
.argus_runs/

# argus.mcp.client 的本地外部 MCP 配置（含 token）— .example 文件入库
.argus/mcp_clients.json

# argus-drive 在 repo 根目录生成的「最近一次报告」产物（symlink + 实体文件）
/__auto__.html
/latest.html
